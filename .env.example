# ── LLM 配置（必填）──────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://hk.ticketpro.cc/v1

# ── LangSmith 可观测性（强烈推荐，免费）────────────────────
# 1. 注册：https://smith.langchain.com
# 2. 左下角 Settings → API Keys → Create API Key
# 3. 填入以下两行：
LANGSMITH_API_KEY=ls__your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=car-export-agent

# ── WhatsApp（可选，演示模式不需要）────────────────────────
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
